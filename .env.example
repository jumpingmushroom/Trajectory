# Trajectory environment.
# Copy this to `.env` before booting; never commit `.env` itself.

# ── M1 (foundation) ───────────────────────────────────────────────
# No required vars at this milestone.
TRAJECTORY_DATA_DIR=/app/data

# ── M2 (auth, coming) ─────────────────────────────────────────────
# Random 32+ char string. Used by Better Auth to sign session cookies.
# BETTER_AUTH_SECRET=changeme-generate-a-real-secret-here

# Comma-separated list of users to seed on first boot if the user table
# is empty. Format: name:initialPassword. Forces password change on first
# login.
# SEED_USERS=johnny:changeme,alina:changeme

# ── M11 (PWA, coming) ─────────────────────────────────────────────
# Used for the PWA manifest's start_url and Better Auth's allowed origins.
# PUBLIC_BASE_URL=http://localhost:5173
