# Trajectory environment.
# Copy this to `.env` before booting; never commit `.env` itself.

# ── Data dir ─────────────────────────────────────────────────────
# Path inside the container. Default works with the bind-mount in
# docker-compose.yml; only override if you've changed the mount.
TRAJECTORY_DATA_DIR=/app/data

# ── Auth (Better Auth) ───────────────────────────────────────────
# Random 32+ char string. Used by Better Auth to sign session cookies.
# In production this MUST be set; the dev fallback is rejected at boot.
# BETTER_AUTH_SECRET=changeme-generate-a-real-secret-here

# ── First admin (v0.2 multiuser) ─────────────────────────────────
# Consumed only when the user table is empty (first boot of a fresh
# instance). Creates a single admin account with this email + password;
# the admin can change their password from /profile after first login.
# Replaces the v0.1 SEED_USERS pattern.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me-on-first-login

# ── PWA + base URL ───────────────────────────────────────────────
# Used for the PWA manifest's start_url, Better Auth's allowed origins,
# and the absolute URL base inside emails (invite + password reset).
# Must match the public scheme/host in production.
# PUBLIC_BASE_URL=http://localhost:5173

# ── Email / SMTP (v0.2) ──────────────────────────────────────────
# Required in production: invites + self-service password resets both
# rely on email. In development, leaving these unset turns the mailer
# into a no-op that prints the would-have-sent message to stdout.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=secret
# SMTP_SECURE=false           # true for port 465 (implicit TLS)
# SMTP_FROM="Trajectory <noreply@trajectory.example.com>"
