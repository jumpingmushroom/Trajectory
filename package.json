		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24",
		"@types/nodemailer": "^8.0.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.3.0",
