		"svelte-check": "^4.4.7",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"workbox-window": "^7.4.0"
	},
	"dependencies": {
		"better-auth": "^1.6.9",
		"better-sqlite3": "^12.9.0",
		"drizzle-orm": "^0.45.2",
		"idb": "^8.0.3",
		"nodemailer": "^8.0.7",
		"sharp": "^0.34.5",
